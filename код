# ===================== HANDLER =====================

@dp.message(F.photo | F.text)
async def handler(message: types.Message):

    uid = message.from_user.id

    if message.photo:

        raw = await load(message.photo[-1].file_id)

        job_id = create_job({
            "type": "ar",
            "image": base64.b64encode(raw).decode()
        })

        await message.answer(f"⚙️ job created: {job_id}")
        return


    if message.text:

        intent = route(message.text)

        if intent == "gen":

            prompt = message.text.replace("/gen", "")

            job_id = create_job({
                "type": "gen",
                "prompt": prompt
            })

            await message.answer(f"🎨 generating job: {job_id}")

        elif intent == "edit":
            await message.answer("📸 send image + /edit prompt")

        elif intent == "faceswap":
            await message.answer("👤 send 2 images")

        else:
            await message.answer("🤖 unknown command")


# ===================== JOB RESULT POLLER =====================

async def job_poller():
    while True:
        await asyncio.sleep(2)


# ===================== MAIN =====================

async def main():
    print("Bot started")

    await start_workers()

    asyncio.create_task(job_poller())

    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())
