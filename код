# ===================== ROUTER v2 =====================

def route(text):
    t = text.lower()

    if "/gen" in t:
        return "gen"
    if "/edit" in t:
        return "edit"
    if "swap" in t:
        return "faceswap"
    if "ar" in t:
        return "ar"

    return "unknown"


# ===================== WORKER SYSTEM =====================

async def worker():
    while True:

        job_raw = r.rpop("jobs")
        if not job_raw:
            await asyncio.sleep(0.2)
            continue

        job = json.loads(job_raw)
        data = json.loads(job["data"])

        try:
            job["status"] = "running"
            update_job(job)

            plugin = plugins.get(data["type"])
            if not plugin:
                continue

            result = await plugin.run(data)

            job["status"] = "done"
            job["result"] = base64.b64encode(result["data"]).decode()

            update_job(job)

        except Exception as e:
            job["status"] = "error"
            job["error"] = str(e)
            job["retries"] += 1
            update_job(job)


# ===================== START WORKERS =====================

async def start_workers():
    for _ in range(4):
        asyncio.create_task(worker())


